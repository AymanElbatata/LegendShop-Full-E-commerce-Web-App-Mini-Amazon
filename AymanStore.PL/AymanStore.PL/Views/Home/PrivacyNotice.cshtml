@{
    ViewData["Title"] = "Privacy Notice";
}


<div class="container">
    <div class="breadcrumb">
        <span>Home > Privacy Notice</span>
    </div>
</div>

<style>
    body {
        font-family: 'Roboto', sans-serif;
        background: #f3f3f3;
        margin: 0;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        background: #fff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    h1 {
        text-align: center;
    }

    .updated {
        text-align: center;
        color: #777;
        margin-bottom: 30px;
    }

    h3 {
        margin-top: 25px;
        color: #222;
    }

    .p55 {
        line-height: 1.8;
        color: #444;
    }

    ul {
        padding-left: 20px;
    }

    li {
        margin-bottom: 8px;
    }

    .footer-links {
        text-align: center;
        margin-top: 40px;
    }

        .footer-links a {
            margin: 0 10px;
            color: #0073e6;
            text-decoration: none;
            font-weight: 500;
        }

            .footer-links a:hover {
                text-decoration: underline;
            }
</style>

<div class="page-container">

    <div class="updated">Last updated: September 2025</div>

    <p class="p55">
        This Privacy Notice explains how we collect, use, and protect your personal information when you use our platform.
    </p>

    <h3>1. Information We Collect</h3>
    <ul>
        <li>Name and account details</li>
        <li>Email address and contact information</li>
        <li>Order and transaction data</li>
        <li>Device and usage information</li>
    </ul>

    <h3>2. How We Use Your Information</h3>
    <p class="p55">We use your information to:</p>
    <ul>
        <li>Provide and manage your account</li>
        <li>Process orders and payments</li>
        <li>Improve our services</li>
        <li>Communicate with you</li>
    </ul>

    <h3>3. Cookies</h3>
    <p class="p55">
        We use cookies to enhance your experience, remember your preferences, and analyze traffic.
    </p>

    <h3>4. Sharing Information</h3>
    <p class="p55">
        We do not sell your personal data. We may share information with:
    </p>
    <ul>
        <li>Payment providers</li>
        <li>Shipping companies</li>
        <li>Legal authorities when required</li>
    </ul>

    <h3>5. Data Security</h3>
    <p class="p55">
        We implement security measures to protect your personal data from unauthorized access or disclosure.
    </p>

    <h3>6. Your Rights</h3>
    <p class="p55">You have the right to:</p>
    <ul>
        <li>Access your data</li>
        <li>Request correction or deletion</li>
        <li>Withdraw consent</li>
    </ul>

    <h3>7. Data Retention</h3>
    <p class="p55">
        We retain your data only as long as necessary for legal and operational purposes.
    </p>

    <h3>8. Children's Privacy</h3>
    <p class="p55">
        Our services are not intended for children under 18.
    </p>

    <h3>9. Changes to This Notice</h3>
    <p class="p55">
        We may update this Privacy Notice from time to time.
    </p>

    <h3>10. Contact Us</h3>
    <p class="p55">
        If you have any questions, contact us at:
        <br />
        <strong>Write us:</strong> <a asp-controller="Home" asp-action="ContactUs">Contact Us</a>
    </p>


</div>