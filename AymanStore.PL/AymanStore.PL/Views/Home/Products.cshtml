@{
    ViewData["Title"] = "Products";
}

<style>
    body {
        font-family: 'Roboto', sans-serif;
        background: #f3f3f3;
        margin: 0;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        background: #fff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    h1 {
        text-align: center;
        margin-bottom: 10px;
    }

    .updated {
        text-align: center;
        color: #777;
        margin-bottom: 30px;
    }

    h3 {
        margin-top: 25px;
        color: #222;
    }

    .p55 {
        line-height: 1.8;
        color: #444;
    }

    ul {
        padding-left: 20px;
    }

    li {
        margin-bottom: 8px;
    }

    hr {
        margin: 30px 0;
        border: none;
        border-top: 1px solid #eee;
    }

    .highlight {
        background: #f1f7ff;
        padding: 15px;
        border-left: 4px solid #0073e6;
        border-radius: 6px;
        margin: 15px 0;
    }

    /* footer links (amazon-like footer) */
    .footer-links {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #e7e7e7;
        font-size: 13px;
    }

        .footer-links a {
            color: #007185;
            text-decoration: none;
            margin: 0 12px;
        }

            .footer-links a:hover {
                text-decoration: underline;
                color: #C7511F;
            }
</style>

<div class="container">
    <div class="breadcrumb">
        <span>Home > Products</span>
    </div>
</div>

<div class="page-container">

    <div class="updated">What we offer on our platform</div>

    <hr />

    <div class="highlight">
        We provide a wide range of high-quality products designed to meet different customer needs,
        offering convenience, affordability, and reliability.
    </div>

    <h3>1. Electronics</h3>
    <p class="p55">
        We offer a variety of electronic products including mobile devices, accessories,
        audio equipment, and smart gadgets designed for modern daily life.
    </p>

    <h3>2. Fashion & Clothing</h3>
    <p class="p55">
        Our platform includes modern clothing collections for men and women,
        featuring casual wear, formal wear, and seasonal fashion items.
    </p>

    <h3>3. Home & Kitchen</h3>
    <p class="p55">
        We provide essential home and kitchen products that help improve comfort,
        organization, and daily household efficiency.
    </p>

    <h3>4. Beauty & Personal Care</h3>
    <p class="p55">
        Customers can find a range of beauty and personal care products,
        including skincare, grooming tools, and wellness items.
    </p>

    <h3>5. Sports & Fitness</h3>
    <p class="p55">
        We offer sports equipment and fitness essentials to support an active and healthy lifestyle.
    </p>

    <h3>6. Product Quality</h3>
    <p class="p55">
        We are committed to providing high-quality products sourced from trusted suppliers
        to ensure customer satisfaction and reliability.
    </p>

    <h3>7. Availability</h3>
    <p class="p55">
        Product availability may vary depending on stock levels and demand.
        We continuously update our catalog to ensure variety and freshness.
    </p>

    <div class="highlight">
        ✔ Wide product categories
        ✔ Trusted suppliers
        ✔ Regular updates and improvements
        ✔ Customer-focused selection
    </div>

    <h3>8. Support</h3>
    <p class="p55">
        If you need help or more information about our products, please visit our Help Center
        or contact our support team.
    </p>
    <div class="footer-links">
        <a asp-controller="Home" asp-action="ConditionsofUse">Conditions of Use</a> |
        <a asp-controller="Home" asp-action="PrivacyPolicy">Privacy Policy</a> |
        <a asp-controller="Home" asp-action="PrivacyNotice">Privacy Notice</a> |
        <a asp-controller="Home" asp-action="ReturnPolicy">Return Policy</a> |
        <a asp-controller="Home" asp-action="HelpPage">Help Center</a> |
        <a asp-controller="Home" asp-action="FAQ">FAQ</a>
    </div>

</div>