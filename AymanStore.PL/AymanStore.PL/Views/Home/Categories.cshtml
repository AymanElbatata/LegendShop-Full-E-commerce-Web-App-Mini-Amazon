@{
    ViewData["Title"] = "Categories";
}

<style>

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        background: #fff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    h1 {
        text-align: center;
        margin-bottom: 10px;
    }

    .updated {
        text-align: center;
        color: #777;
        margin-bottom: 30px;
    }

    h3 {
        margin-top: 25px;
        color: #222;
    }

    .p55 {
        line-height: 1.8;
        color: #444;
    }

    ul {
        padding-left: 20px;
    }

    li {
        margin-bottom: 8px;
    }

    hr {
        margin: 30px 0;
        border: none;
        border-top: 1px solid #eee;
    }

    .highlight {
        background: #f1f7ff;
        padding: 15px;
        border-left: 4px solid #0073e6;
        border-radius: 6px;
        margin: 15px 0;
    }

    .category-box {
        background: #fafafa;
        padding: 15px;
        border-radius: 8px;
        margin: 10px 0;
        border-left: 4px solid #0073e6;
    }

    /* footer links (amazon-like footer) */
    .footer-links {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #e7e7e7;
        font-size: 13px;
    }

        .footer-links a {
            color: #007185;
            text-decoration: none;
            margin: 0 12px;
        }

            .footer-links a:hover {
                text-decoration: underline;
                color: #C7511F;
            }
</style>

<div class="container">
    <div class="breadcrumb">
        <span>Home > Categories</span>
    </div>
</div>

<div class="page-container">

    <div class="updated">Explore what we offer on our platform</div>

    <hr />

    <div class="highlight">
        Our platform is organized into multiple categories to help customers easily find products that match their needs and interests.
    </div>

    <h3>Electronics</h3>
    <div class="category-box">
        Includes mobile phones, accessories, smart devices, headphones, and modern tech gadgets.
    </div>

    <h3>Fashion & Clothing</h3>
    <div class="category-box">
        A wide range of clothing for men and women including casual wear, formal outfits, and seasonal fashion.
    </div>

    <h3>Home & Kitchen</h3>
    <div class="category-box">
        Essential household items, kitchen tools, furniture accessories, and home improvement products.
    </div>

    <h3>Beauty & Personal Care</h3>
    <div class="category-box">
        Skincare, cosmetics, grooming tools, and personal hygiene products for daily use.
    </div>

    <h3>Sports & Fitness</h3>
    <div class="category-box">
        Equipment and accessories for fitness training, outdoor sports, and healthy lifestyle activities.
    </div>

    <h3>Baby & Kids</h3>
    <div class="category-box">
        Products designed for children including toys, clothing, and daily care essentials.
    </div>

    <h3>Books & Education</h3>
    <div class="category-box">
        Educational materials, books, and learning resources for all ages.
    </div>

    <div class="highlight">
        ✔ Easy navigation by category
        ✔ Organized product structure
        ✔ Better shopping experience
        ✔ Constantly expanding catalog
    </div>

    <h3>Need Help?</h3>
    <p class="p55">
        If you need assistance finding a category or product, visit our Help Center or contact support.
    </p>

    <div class="footer-links">
        <a asp-controller="Home" asp-action="ConditionsofUse">Conditions of Use</a> |
        <a asp-controller="Home" asp-action="PrivacyPolicy">Privacy Policy</a> |
        <a asp-controller="Home" asp-action="PrivacyNotice">Privacy Notice</a> |
        <a asp-controller="Home" asp-action="ReturnPolicy">Return Policy</a> |
        <a asp-controller="Home" asp-action="HelpPage">Help Center</a> |
        <a asp-controller="Home" asp-action="FAQ">FAQ</a>
    </div>

</div>
