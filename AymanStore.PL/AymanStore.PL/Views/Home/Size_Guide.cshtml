@{
    ViewData["Title"] = "Size Guide";
}

<style>
    body {
        font-family: 'Roboto', sans-serif;
        background: #f3f3f3;
        margin: 0;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        background: #fff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    h1 {
        text-align: center;
        margin-bottom: 10px;
    }

    .updated {
        text-align: center;
        color: #777;
        margin-bottom: 30px;
    }

    h3 {
        margin-top: 25px;
        color: #222;
    }

    .p55 {
        line-height: 1.8;
        color: #444;
    }

    hr {
        margin: 30px 0;
        border: none;
        border-top: 1px solid #eee;
    }

    .highlight {
        background: #f1f7ff;
        padding: 15px;
        border-left: 4px solid #0073e6;
        border-radius: 6px;
        margin: 15px 0;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
        background: #fff;
    }

        table th, table td {
            border: 1px solid #eee;
            padding: 12px;
            text-align: center;
        }

        table th {
            background: #f7f7f7;
            font-weight: 600;
        }

    .footer-links {
        text-align: center;
        margin-top: 40px;
    }

        .footer-links a {
            margin: 0 10px;
            color: black;
            text-decoration: none;
            font-weight: 500;
        }

            .footer-links a:hover {
                text-decoration: underline;
            }
</style>
<div class="container">
    <div class="breadcrumb">
        <span>Home > Size Guide</span>
    </div>
</div>


<div class="page-container">

    <div class="updated">Find the perfect fit for your purchase</div>

    <hr />

    <div class="highlight">
        Use this guide to choose the correct size before placing your order.
        Sizes may vary slightly depending on the product type and brand.
    </div>

    <h3>1. Men's Clothing Sizes</h3>

    <table>
        <tr>
            <th>Size</th>
            <th>Chest (cm)</th>
            <th>Waist (cm)</th>
        </tr>
        <tr>
            <td>S</td>
            <td>86 - 94</td>
            <td>70 - 78</td>
        </tr>
        <tr>
            <td>M</td>
            <td>94 - 102</td>
            <td>78 - 86</td>
        </tr>
        <tr>
            <td>L</td>
            <td>102 - 110</td>
            <td>86 - 94</td>
        </tr>
        <tr>
            <td>XL</td>
            <td>110 - 118</td>
            <td>94 - 102</td>
        </tr>
    </table>

    <h3>2. Women's Clothing Sizes</h3>

    <table>
        <tr>
            <th>Size</th>
            <th>Bust (cm)</th>
            <th>Waist (cm)</th>
            <th>Hips (cm)</th>
        </tr>
        <tr>
            <td>S</td>
            <td>80 - 88</td>
            <td>62 - 70</td>
            <td>86 - 94</td>
        </tr>
        <tr>
            <td>M</td>
            <td>88 - 96</td>
            <td>70 - 78</td>
            <td>94 - 102</td>
        </tr>
        <tr>
            <td>L</td>
            <td>96 - 104</td>
            <td>78 - 86</td>
            <td>102 - 110</td>
        </tr>
    </table>

    <h3>3. Shoes Size Guide</h3>

    <table>
        <tr>
            <th>EU</th>
            <th>US</th>
            <th>Foot Length (cm)</th>
        </tr>
        <tr>
            <td>39</td>
            <td>6</td>
            <td>24.5</td>
        </tr>
        <tr>
            <td>40</td>
            <td>7</td>
            <td>25.0</td>
        </tr>
        <tr>
            <td>41</td>
            <td>8</td>
            <td>25.5</td>
        </tr>
        <tr>
            <td>42</td>
            <td>9</td>
            <td>26.0</td>
        </tr>
    </table>

    <h3>4. Important Notes</h3>
    <p class="p55">
        Always check the product description for brand-specific sizing differences.
        If you are between sizes, we recommend choosing the larger size for better comfort.
    </p>

    <div class="highlight">
        ✔ Measurements are in centimeters (cm)
        ✔ Sizes may vary slightly by brand
        ✔ When in doubt, choose one size up
    </div>


</div>