@model List<ShippingCompanyCostTBL_VM>

@{
    ViewData["Title"] = "Manage Shipping Company Cost";
}

<style>
    .btn-amazon {
        background: linear-gradient(135deg, #ff9900 0%, #ff8800 100%);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-amazon:hover {
            background: linear-gradient(135deg, #ff8800 0%, #ff7700 100%);
            transform: translateY(-1px);
            color: white;
        }

    .shipping-cost-row {
        transition: all 0.3s ease;
    }

        .shipping-cost-row:hover {
            background-color: #fff9f0;
        }

    .form-control:focus, .form-select:focus {
        border-color: #ff9900;
        box-shadow: 0 0 0 2px rgba(255,153,0,0.1);
        background-color: white !important;
    }

    .card {
        border-radius: 12px;
    }

    .table th {
        font-weight: 600;
        font-size: 14px;
    }

    .badge {
        padding: 6px 12px;
        font-size: 13px;
    }
</style>

<div class="container">
    <div class="breadcrumb">
        <span>Admin > ShippingCompany Cost</span>
    </div>
</div>


<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
@*             <h2 class="fw-bold mb-1" style="color: #232f3e;">
                <i class="fas fa-dollar-sign me-2"></i>Shipping Cost Management
            </h2>
            <p class="text-muted">Manage shipping costs by company and country</p>
 *@        </div>
        <div class="text-end">
            <span class="badge bg-secondary">Total: @Model.Count shipping costs</span>
        </div>
    </div>

    <!-- Add Shipping Cost Card -->
    <div class="card shadow-sm mb-4 border-0 rounded-3">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold" style="color: #ff9900;">
                <i class="fas fa-plus-circle me-2"></i>Add New Shipping Cost
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Shipping Company <span class="text-danger">*</span></label>
                    <select id="newShippingCompanyId" class="form-select">
                        <option value="">-- Select Company --</option>
                        @foreach (var company in ViewBag.ShippingCompanies)
                        {
                            <option value="@company.ID">@company.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Send From Country <span class="text-danger">*</span></label>
                    <select id="newSendFromId" class="form-select">
                        <option value="">-- Select Country --</option>
                        @foreach (var country in ViewBag.Countries)
                        {
                            <option value="@country.ID">@country.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Send To Country <span class="text-danger">*</span></label>
                    <select id="newSendToId" class="form-select">
                        <option value="">-- Select Country --</option>
                        @foreach (var country in ViewBag.Countries)
                        {
                            <option value="@country.ID">@country.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Cost ($) <span class="text-danger">*</span></label>
                    <input type="number" id="newCost" class="form-control" placeholder="0.00" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-amazon w-100" onclick="addShippingCost()">
                        <i class="fas fa-plus me-2"></i>Add
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Shipping Costs Table -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold" style="color: #232f3e;">
                <i class="fas fa-list me-2"></i>All Shipping Costs
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color: #232f3e;">
                        <tr>
                            <th class="text-white py-3 ps-3">#</th>
                            <th class="text-white py-3">Shipping Company</th>
                            <th class="text-white py-3">Send From</th>
                            <th class="text-white py-3">Send To</th>
                            <th class="text-white py-3">Cost ($)</th>
                            <th class="text-white py-3 text-center" width="150">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="shippingCostsTableBody">
                        @{
                            int counter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID" class="shipping-cost-row">
                                <td class="ps-3 align-middle">@counter</td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="shippingCompanyId_@item.ID"
                                            style="min-width: 150px;">
                                        <option value="">-- Select Company --</option>
                                        @foreach (var company in ViewBag.ShippingCompanies)
                                        {
                                            if (company.ID == item.ShippingCompanyTBLId)
                                            {
                                                <option value="@company.ID" selected>@company.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@company.ID">@company.Name</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="sendFromId_@item.ID"
                                            style="min-width: 150px;">
                                        <option value="">-- Select Country --</option>
                                        @foreach (var country in ViewBag.Countries)
                                        {
                                            if (country.ID == item.CountryTBLSendFromId)
                                            {
                                                <option value="@country.ID" selected>@country.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@country.ID">@country.Name</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="sendToId_@item.ID"
                                            style="min-width: 150px;">
                                        <option value="">-- Select Country --</option>
                                        @foreach (var country in ViewBag.Countries)
                                        {
                                            if (country.ID == item.CountryTBLSendToId)
                                            {
                                                <option value="@country.ID" selected>@country.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@country.ID">@country.Name</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <input type="number" class="form-control w-25 form-control-sm border-0 bg-light"
                                           id="cost_@item.ID"
                                           value="@item.Cost"
                                           style="min-width: 100px;" />
                                </td>
                                <td class="text-center align-middle d-flex align-items-center justify-content-center">
                                    <button class="btn btn-sm btn-success me-2" onclick="updateShippingCost(@item.ID)" title="Save changes">
                                        <i class="fas fa-save me-1"></i>Save
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteShippingCost(@item.ID)" title="Delete cost">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </td>
                            </tr>
                            counter++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>



    <script>
        // Add Shipping Cost
        function addShippingCost() {
            var shippingCompanyId = $("#newShippingCompanyId").val();
            var sendFromId = $("#newSendFromId").val();
            var sendToId = $("#newSendToId").val();
            var cost = $("#newCost").val();

            if (!shippingCompanyId) {
                showNotification('Please select a shipping company', 'error');
                return;
            }

            if (!sendFromId) {
                showNotification('Please select send from country', 'error');
                return;
            }

            if (!sendToId) {
                showNotification('Please select send to country', 'error');
                return;
            }

            if (!cost || cost <= 0) {
                showNotification('Please enter a valid cost', 'error');
                return;
            }

            var addBtn = event.target;
            var originalText = $(addBtn).html();
            $(addBtn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Adding...');

            $.ajax({
                url: '/ShippingCompanyCost/AddShippingCost',
                type: 'POST',
                data: {
                    ShippingCompanyTBLId: shippingCompanyId,
                    CountryTBLSendFromId: sendFromId,
                    CountryTBLSendToId: sendToId,
                    Cost: cost
                },
                success: function(response) {
                    if (response.success) {
                        // Get selected names for display
                        var companyName = $("#newShippingCompanyId option:selected").text();
                        var sendFromName = $("#newSendFromId option:selected").text();
                        var sendToName = $("#newSendToId option:selected").text();

                        // Add new row to table dynamically
                        var newRow = `
                            <tr id="row_${response.id}" class="shipping-cost-row">
                                <td class="ps-3 align-middle">${$('#shippingCostsTableBody tr').length + 1}</td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="shippingCompanyId_${response.id}"
                                            style="min-width: 150px;">
                                        ${getAllShippingCompaniesOptions(response.shippingCompanyId)}
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="sendFromId_${response.id}"
                                            style="min-width: 150px;">
                                        ${getAllCountriesOptions(response.sendFromId)}
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <select class="form-select form-select-sm border-0 bg-light"
                                            id="sendToId_${response.id}"
                                            style="min-width: 150px;">
                                        ${getAllCountriesOptions(response.sendToId)}
                                    </select>
                                </td>
                                <td class="align-middle">
                                    <input type="number" class="form-control w-25 form-control-sm border-0 bg-light"
                                           id="cost_${response.id}"
                                           value="${cost}"
                                           style="min-width: 100px;" />
                                </td>
                                <td class="text-center align-middle d-flex align-items-center justify-content-center">
                                    <button class="btn btn-sm btn-success me-2" onclick="updateShippingCost(${response.id})">
                                        <i class="fas fa-save me-1"></i>Save
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteShippingCost(${response.id})">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </td>
                            <tr>
                        `;
                        $('#shippingCostsTableBody').prepend(newRow);

                        // Clear inputs
                        $("#newShippingCompanyId").val('');
                        $("#newSendFromId").val('');
                        $("#newSendToId").val('');
                        $("#newCost").val('');

                        showNotification('Shipping cost added successfully!', 'success');
                    } else {
                        showNotification(response.message || 'Add failed', 'error');
                    }
                },
                error: function() {
                    showNotification('Error adding shipping cost', 'error');
                },
                complete: function() {
                    $(addBtn).prop('disabled', false).html(originalText);
                }
            });
        }

        // Update Shipping Cost
        function updateShippingCost(id) {
            var shippingCompanyId = $("#shippingCompanyId_" + id).val();
            var sendFromId = $("#sendFromId_" + id).val();
            var sendToId = $("#sendToId_" + id).val();
            var cost = $("#cost_" + id).val();

            if (!shippingCompanyId) {
                showNotification('Please select a shipping company', 'error');
                return;
            }

            if (!sendFromId) {
                showNotification('Please select send from country', 'error');
                return;
            }

            if (!sendToId) {
                showNotification('Please select send to country', 'error');
                return;
            }

            if (!cost || cost <= 0) {
                showNotification('Please enter a valid cost', 'error');
                return;
            }

            var updateBtn = event.target;
            var originalText = $(updateBtn).html();
            $(updateBtn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            $.ajax({
                url: '/ShippingCompanyCost/UpdateShippingCost',
                type: 'POST',
                data: {
                    Id: id,
                    ShippingCompanyTBLId: shippingCompanyId,
                    CountryTBLSendFromId: sendFromId,
                    CountryTBLSendToId: sendToId,
                    Cost: cost
                },
                success: function(response) {
                    if (response.success) {
                        // Visual feedback - highlight row
                        var row = $("#row_" + id);
                        row.css('background-color', '#d4edda');
                        setTimeout(function() {
                            row.css('background-color', '');
                        }, 1000);
                        showNotification('Shipping cost updated successfully!', 'success');
                    } else {
                        showNotification(response.message || 'Update failed', 'error');
                    }
                },
                error: function() {
                    showNotification('Error updating shipping cost', 'error');
                },
                complete: function() {
                    $(updateBtn).prop('disabled', false).html(originalText);
                }
            });
        }

        // Delete Shipping Cost
        function deleteShippingCost(id) {
            if (!confirm("Are you sure you want to delete this shipping cost? This action cannot be undone.")) return;

            var deleteBtn = event.target;
            var originalText = $(deleteBtn).html();
            $(deleteBtn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

            $.ajax({
                url: '/ShippingCompanyCost/DeleteShippingCost',
                type: 'POST',
                data: { id: id },
                success: function(response) {
                    if (response.success) {
                        // Animate row removal
                        var row = $("#row_" + id);
                        row.fadeOut(300, function() {
                            $(this).remove();
                            // Update row numbers
                            updateRowNumbers();
                        });
                        showNotification('Shipping cost deleted successfully!', 'success');
                    } else {
                        showNotification(response.message || 'Delete failed', 'error');
                    }
                },
                error: function() {
                    showNotification('Error deleting shipping cost', 'error');
                },
                complete: function() {
                    $(deleteBtn).prop('disabled', false).html(originalText);
                }
            });
        }

        // Get all shipping companies options for dropdown
        function getAllShippingCompaniesOptions(selectedId) {
            var options = '<option value="">-- Select Company --</option>';
            @foreach (var company in ViewBag.ShippingCompanies)
            {
                    <text>
                    if (selectedId == @company.ID) {
                        options += '<option value="@company.ID" selected>@company.Name</option>';
                    } else {
                        options += '<option value="@company.ID">@company.Name</option>';
                    }
                    </text>
            }
            return options;
        }

        // Get all countries options for dropdown
        function getAllCountriesOptions(selectedId) {
            var options = '<option value="">-- Select Country --</option>';
            @foreach (var country in ViewBag.Countries)
            {
                    <text>
                    if (selectedId == @country.ID) {
                        options += '<option value="@country.ID" selected>@country.Name</option>';
                    } else {
                        options += '<option value="@country.ID">@country.Name</option>';
                    }
                    </text>
            }
            return options;
        }

        // Update row numbers after deletion
        function updateRowNumbers() {
            $('#shippingCostsTableBody tr').each(function(index) {
                $(this).find('td:first').text(index + 1);
            });
        }

        // Show notification
        function showNotification(message, type) {
            var notification = $(`
                <div class="alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed top-0 end-0 m-3"
                     style="z-index: 9999; min-width: 300px; border-radius: 8px;">
                    <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `);
            $('body').append(notification);
            setTimeout(function() {
                notification.fadeOut(function() {
                    $(this).remove();
                });
            }, 3000);
        }

        // Escape HTML to prevent XSS
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
    </script>
