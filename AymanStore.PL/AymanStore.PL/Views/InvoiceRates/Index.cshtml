@model List<InvoiceRateTBL_VM>

@{
    ViewData["Title"] = "Manage Invoice Rates";
}


<style>
    .btn-amazon {
        background: linear-gradient(135deg, #ff9900 0%, #ff8800 100%);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-amazon:hover {
            background: linear-gradient(135deg, #ff8800 0%, #ff7700 100%);
            transform: translateY(-1px);
            color: white;
        }

    .rate-row {
        transition: background 0.2s ease;
    }

        .rate-row:hover {
            background-color: #fff9f0;
        }

    .form-control:focus {
        border-color: #ff9900;
        box-shadow: 0 0 0 2px rgba(255,153,0,0.1);
    }

    .card {
        border-radius: 16px;
    }

    .table th {
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        color: #ff9900;
        font-weight: 600;
    }
</style>

<div class="container">
    <div class="breadcrumb">
        <span>Admin > Invoice Rates</span>
    </div>
</div>

<div class="container-fluid px-4 py-4">
    <!-- Header Section -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
@*             <h2 class="fw-bold mb-1" style="color: #232f3e;">
                <i class="fas fa-percent me-2" style="color: #ff9900;"></i>Invoice Rate Management
            </h2>
            <p class="text-muted small mb-0">Configure VAT and profit percentage rates for invoices</p>
 *@        </div>
        <button class="btn btn-amazon mt-2 mt-md-0" onclick="openAddModal()">
            <i class="fas fa-plus-circle me-2"></i>Create New Rate
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                            <i class="fas fa-chart-line text-primary fs-5"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Rates</div>
                            <div class="fw-bold fs-3">@Model.Count</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                            <i class="fas fa-dollar-sign text-success fs-5"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Avg VAT Rate</div>
                            <div class="fw-bold fs-3">
                                @(Model != null && Model.Any(x => x.VATRate.HasValue)
                                                                ? Model.Where(x => x.VATRate.HasValue).Average(x => x.VATRate.Value).ToString("F0")
                                                                : "0")%
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                            <i class="fas fa-chart-simple text-warning fs-5"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Avg Profit Rate</div>
                            <div class="fw-bold fs-3">
                                @(Model != null && Model.Any(x => x.ProfitRate.HasValue)
                                                                ? Model.Where(x => x.ProfitRate.HasValue)
                                                                .Average(x => x.ProfitRate.Value)
                                                                .ToString("F0")
                                                                : "0")%
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Rates Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-semibold">
                <i class="fas fa-list me-2" style="color: #ff9900;"></i>Rate List
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3" style="width: 8%">#</th>
                            <th>VAT Rate</th>
                            <th>Profit Rate</th>
                            <th class="text-center" style="width: 18%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID" class="rate-row">
                                <td class="ps-3 fw-semibold">@counter</td>
                                <td>
                                    <div class="input-group input-group-sm" style="max-width: 140px;">
                                        <input type="number" class="form-control text-center border-0 bg-light"
                                               id="vat_@item.ID" value="@item.VATRate"
                                               min="0" max="100" step="1" />
                                        <span class="input-group-text bg-light text-muted">%</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="input-group input-group-sm" style="max-width: 140px;">
                                        <input type="number" class="form-control text-center border-0 bg-light"
                                               id="profit_@item.ID" value="@item.ProfitRate"
                                               min="0" max="100" step="1" />
                                        <span class="input-group-text bg-light text-muted">%</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-center">
                                        <button class="btn btn-sm btn-success px-3" onclick="updateRate(@item.ID)" title="Save changes">
                                            <i class="fas fa-check me-1"></i> Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger px-3" onclick="deleteRate(@item.ID)" title="Delete rate">
                                            <i class="fas fa-trash-alt me-1"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            counter++;
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fa-3x mb-2 d-block"></i>
                                    No rates found. Click "Create New Rate" to add one.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow-lg">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #232f3e 0%, #1a2533 100%);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-plus-circle me-2"></i>Create New Rate
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-chart-line me-1" style="color: #ff9900;"></i>
                        VAT Rate (%)
                    </label>
                    <div class="input-group">
                        <input type="number" id="newVatRate" class="form-control form-control-lg"
                               placeholder="Enter VAT rate" min="0" max="100" />
                        <span class="input-group-text bg-light fw-semibold">%</span>
                    </div>
                    <small class="text-muted">Value Added Tax percentage applied to invoices</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold mb-2">
                        <i class="fas fa-dollar-sign me-1" style="color: #ff9900;"></i>
                        Profit Rate (%)
                    </label>
                    <div class="input-group">
                        <input type="number" id="newProfitRate" class="form-control form-control-lg"
                               placeholder="Enter profit rate" min="0" max="100" />
                        <span class="input-group-text bg-light fw-semibold">%</span>
                    </div>
                    <small class="text-muted">Profit margin percentage added to product costs</small>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-amazon px-4" onclick="addRate()">
                    <i class="fas fa-save me-1"></i>Save Rate
                </button>
            </div>
        </div>
    </div>
</div>


<script>
    function openAddModal() {
        $('#newVatRate').val('');
        $('#newProfitRate').val('');
        $('#addModal').modal('show');
    }

    function addRate() {
        var vatRate = $('#newVatRate').val();
        var profitRate = $('#newProfitRate').val();

        if (!vatRate || !profitRate) {
            alert('Please fill all fields');
            return;
        }

        var btn = event.target;
        var originalHtml = $(btn).html();
        $(btn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Saving...');

        $.ajax({
            url: '/InvoiceRates/AddInvoiceRates',
            type: 'POST',
            data: {
                VATRate: vatRate,
                ProfitRate: profitRate
            },
            success: function(response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert(response.message || 'Error adding rate');
                    $(btn).prop('disabled', false).html(originalHtml);
                }
            },
            error: function() {
                alert('Error adding rate');
                $(btn).prop('disabled', false).html(originalHtml);
            }
        });
    }

    function updateRate(id) {
        var vatRate = $('#vat_' + id).val();
        var profitRate = $('#profit_' + id).val();

        var btn = event.target;
        var originalHtml = $(btn).html();
        $(btn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

        $.ajax({
            url: '/InvoiceRates/UpdateInvoiceRates',
            type: 'POST',
            data: {
                ID: id,
                VATRate: vatRate,
                ProfitRate: profitRate
            },
            success: function(response) {
                if (response.success) {
                    $('#row_' + id).css('background-color', '#d4edda');
                    setTimeout(function() {
                        $('#row_' + id).css('background-color', '');
                    }, 1000);
                    alert('Rate updated successfully');
                } else {
                    alert(response.message || 'Error updating rate');
                }
                $(btn).prop('disabled', false).html(originalHtml);
            },
            error: function() {
                alert('Error updating rate');
                $(btn).prop('disabled', false).html(originalHtml);
            }
        });
    }

    function deleteRate(id) {
        if (!confirm('Are you sure you want to delete this rate?')) return;

        var btn = event.target;
        var originalHtml = $(btn).html();
        $(btn).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');

        $.ajax({
            url: '/InvoiceRates/DeleteInvoiceRates',
            type: 'POST',
            data: { id: id },
            success: function(response) {
                if (response.success) {
                    $('#row_' + id).fadeOut(300, function() {
                        $(this).remove();
                    });
                } else {
                    alert(response.message || 'Error deleting rate');
                    $(btn).prop('disabled', false).html(originalHtml);
                }
            },
            error: function() {
                alert('Error deleting rate');
                $(btn).prop('disabled', false).html(originalHtml);
            }
        });
    }
</script>
