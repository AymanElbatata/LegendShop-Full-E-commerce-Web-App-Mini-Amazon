@model Products_VM

<style>
    /* Amazon-inspired styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: #eaeded;
        font-family: 'Amazon Ember', Arial, sans-serif;
    }

    .product-container {
        background-color: #f3f3f3;
        padding: 20px;
        min-height: 100vh;
    }

    /* Search Bar */
    .search-bar {
        background: white;
        padding: 25px;
        border-radius: 8px;
        margin-bottom: 25px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

        .search-bar input {
            border: 2px solid #ddd;
            border-radius: 4px;
            padding: 12px;
            font-size: 16px;
        }

            .search-bar input:focus {
                border-color: #ff9900;
                outline: none;
                box-shadow: 0 0 0 2px rgba(255,153,0,0.2);
            }

    /* Product Cards */
    .product-card {
        background: white;
        border-radius: 8px;
        margin-bottom: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

    .product-header {
        background: linear-gradient(135deg, #232f3e 0%, #1a2533 100%);
        color: white;
        padding: 18px 20px;
        cursor: pointer;
        transition: background 0.3s ease;
    }

        .product-header:hover {
            background: linear-gradient(135deg, #2a3a4a 0%, #1f2c3d 100%);
        }

        .product-header .badge {
            background-color: #ff9900;
            color: #232f3e;
            font-weight: bold;
            margin-left: 10px;
            padding: 5px 10px;
        }

    .product-body {
        padding: 0;
        display: none;
        animation: fadeIn 0.5s ease;
    }

        .product-body.active {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Product Details Section */
    .product-details-section {
        padding: 25px;
        background: #f8f9fa;
    }

    .section-title {
        color: #232f3e;
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #ff9900;
        display: inline-block;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin-bottom: 25px;
    }

    .info-item {
        background: white;
        padding: 12px;
        border-radius: 6px;
        border-left: 3px solid #ff9900;
    }

    .info-label {
        font-weight: bold;
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .info-value {
        color: #232f3e;
        font-size: 14px;
        font-weight: 500;
    }

    /* Photo Gallery */
    .photo-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 15px;
        margin-top: 15px;
        margin-bottom: 25px;
    }

    .photo-item {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 10px;
        text-align: center;
        background: white;
        transition: all 0.3s ease;
        position: relative;
    }

        .photo-item:hover {
            border-color: #ff9900;
            transform: scale(1.02);
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

    .photo-thumbnail {
        width: 100%;
        height: 130px;
        object-fit: cover;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    /* Specifications */
    .specs-container {
        margin-top: 15px;
        margin-bottom: 25px;
    }

    .spec-item {
        background: white;
        padding: 12px 15px;
        margin: 8px 0;
        border-radius: 6px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
        border: 1px solid #e0e0e0;
    }

        .spec-item:hover {
            border-color: #ff9900;
            background: #fff9f0;
        }

    .spec-content {
        flex: 1;
    }

    /*     .spec-key {
            font-weight: bold;
            color: #232f3e;
            margin-right: 15px;
        } */

    .spec-value {
        color: #666;
    }

    /* Buttons */
    .btn-amazon {
        background: linear-gradient(135deg, #ff9900 0%, #ff8800 100%);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-amazon:hover {
            background: linear-gradient(135deg, #ff8800 0%, #ff7700 100%);
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(255,153,0,0.3);
        }

    .btn-amazon-small {
        padding: 5px 12px;
        font-size: 12px;
    }

    .btn-danger {
        background: #dc3545;
        border: none;
        padding: 5px 12px;
        border-radius: 4px;
        color: white;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.3s ease;
    }

        .btn-danger:hover {
            background: #c82333;
            transform: translateY(-1px);
        }

    .btn-warning {
        background: #ffc107;
        border: none;
        padding: 5px 12px;
        border-radius: 4px;
        color: #232f3e;
        cursor: pointer;
        font-size: 12px;
        margin-right: 5px;
        transition: all 0.3s ease;
    }

        .btn-warning:hover {
            background: #e0a800;
            transform: translateY(-1px);
        }

    .plus-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #ff9900;
        color: white;
        border-radius: 50%;
        cursor: pointer;
        margin-left: 12px;
        transition: all 0.3s ease;
        font-size: 18px;
        font-weight: bold;
    }

        .plus-button:hover {
            background: #ff8800;
            transform: scale(1.1) rotate(90deg);
        }

    /* Modal Styles */
    .modal-content {
        border-radius: 12px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }

    .modal-header {
        background: linear-gradient(135deg, #232f3e 0%, #1a2533 100%);
        color: white;
        border-radius: 12px 12px 0 0;
        padding: 20px;
    }

        .modal-header .close {
            color: white;
            opacity: 0.8;
            text-shadow: none;
        }

            .modal-header .close:hover {
                opacity: 1;
            }

    .modal-title {
        font-weight: bold;
    }

    .modal-body {
        padding: 25px;
    }

    /* Form Styles */
    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-weight: 600;
            color: #232f3e;
            margin-bottom: 8px;
            display: block;
        }

    .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 6px;
        padding: 10px 12px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #ff9900;
            box-shadow: 0 0 0 3px rgba(255,153,0,0.1);
            outline: none;
        }

    select.form-control {
        cursor: pointer;
    }

    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }

    /* Current Photo */
    .current-photo {
        text-align: center;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 8px;
        margin-bottom: 15px;
    }

        .current-photo img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

    /* Loading Spinner */
    .loading-spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255,153,0,0.3);
        border-radius: 50%;
        border-top-color: #ff9900;
        animation: spin 1s ease-in-out infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 8px;
    }

        .empty-state i {
            font-size: 80px;
            color: #ccc;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: #666;
            margin-bottom: 10px;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .product-container {
            padding: 10px;
        }

        .product-header .row > div {
            margin-bottom: 10px;
        }

        .photo-gallery {
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }

        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    .modal-content .close {
        display: none;
    }
</style>


<div class="product-container">
    <!-- Search Section -->
    <div class="search-bar">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control" placeholder="Search products by name, brand, or model..."
                           onkeypress="if(event.key === 'Enter') searchProducts()">
                    <div class="input-group-append d-flex justify-content-center align-items-center ms-1">
                        <button class="btn btn-amazon" onclick="searchProducts()">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </div>
            @*                 <div class="col-md-4">
                    <button class="btn btn-secondary" onclick="clearSearch()">
                        <i class="fas fa-undo"></i> Clear
                    </button>
                </div> *@
        </div>
    </div>

    <!-- Products List -->
    <div id="productsList">
        @if (Model.ProductTBL_VM.Any())
        {
            foreach (var product in Model.ProductTBL_VM)
            {
                <div class="product-card" data-product-id="@product.ID">
                    <div class="product-header" onclick="toggleProduct(@product.ID)">
                        <div class="row align-items-center">
                            <div class="col-md-5">
                                <i class="fas fa-chevron-down" style="margin-right: 10px;"></i>
                                <strong>@product.Name</strong>
                                @if (!string.IsNullOrEmpty(product.Barcode))
                                {
                                    <span class="badge">@product.Barcode</span>
                                }
                            </div>
                            <div class="col-md-3">
                                <i class="fas fa-tag"></i> $@(product.SellingPrice?.ToString("N0") ?? "0")
                            </div>
                            <div class="col-md-2">
                                <i class="fas fa-box"></i> Qty: @(product.Quantity ?? 0)
                            </div>
                            <div class="col-md-2 text-right">
                                <button class="btn btn-warning btn-sm" onclick="event.stopPropagation(); editProduct(@product.ID)">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); deleteProduct(@product.ID, '@product.Name.Replace("'", "\\'")')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="product-body" id="product-@product.ID">
                        <div class="product-details-section">
                            <div class="row">
                                <div class="col-md-6">
                                    <h4 class="section-title">
                                        <i class="fas fa-info-circle"></i> Product Details
                                    </h4>
                                    <div class="info-grid">
                                        <div class="info-item">
                                            <div class="info-label">Description</div>
                                            <div class="info-value">@(product.Description ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Model</div>
                                            <div class="info-value">@(product.Model ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Material</div>
                                            <div class="info-value">@(product.Material ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Color</div>
                                            <div class="info-value">@(product.Color ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Weight</div>
                                            <div class="info-value">@(product.Weight ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Size</div>
                                            <div class="info-value">@(product.Size ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Brand</div>
                                            <div class="info-value">@(product.Brand ?? "N/A")</div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Status</div>
                                            <div class="info-value">
                                                @if (product.IsPublished)
                                                {
                                                    <span class="badge badge-success text-black">Published</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Draft</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <h4 class="section-title">
                                        <i class="fas fa-images"></i> Photos
                                        <span class="plus-button" onclick="event.stopPropagation(); openPhotoModal(@product.ID)">
                                            <i class="fas fa-plus"></i>
                                        </span>
                                    </h4>
                                    <div class="photo-gallery" id="photos-@product.ID">
                                        @{
                                            var productPhotos = Model.ProductPhotoTBL_VM.Where(p => p.ProductTBLId == product.ID);
                                        }
                                        @if (productPhotos.Any())
                                        {
                                            foreach (var photo in productPhotos)
                                            {
                                                <div class="photo-item" id="photo-@photo.ID">
                                                    <img src="~/Images/Products/@photo.Image" class="photo-thumbnail" alt="Product photo">
                                                    <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); deletePhoto(@photo.ID, @product.ID)">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="text-muted">No photos uploaded</div>
                                        }
                                    </div>

                                    <h4 class="section-title" style="margin-top: 20px;">
                                        <i class="fas fa-list"></i> Specifications
                                        <span class="plus-button" onclick="event.stopPropagation(); openSpecModal(@product.ID)">
                                            <i class="fas fa-plus"></i>
                                        </span>
                                    </h4>
                                    <div class="specs-container" id="specs-@product.ID">
                                        @{
                                            var productSpecs = Model.ProductSpecificationTBL_VM.Where(s => s.ProductTBLId == product.ID);
                                        }
                                        @if (productSpecs.Any())
                                        {
                                            foreach (var spec in productSpecs)
                                            {
                                                <div class="spec-item" id="spec-@spec.ID">
                                                    <div class="spec-content">
                                                        <span class="spec-value">@spec.Name</span>
                                                    </div>
                                                    <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); deleteSpec(@spec.ID, @product.ID)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="text-muted">No specifications added</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <h3>No Products Found</h3>
                <p>Start by adding your first product</p>
            </div>
        }
    </div>
</div>

<!-- Photo Upload Modal -->
<div class="modal fade" id="photoModal" tabindex="-1" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-camera"></i> Upload Product Photo
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="closeModal('#photoModal')">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="photoUploadForm" enctype="multipart/form-data">
                    <input type="hidden" id="photoProductId" name="ProductId">
                    <div class="form-group">
                        <label>Select Photo</label>
                        <input type="file" id="photoFile" name="Photo" class="form-control" accept="image/*" onchange="previewPhoto(this)">
                        <small class="form-text text-muted">Supported formats: JPG, PNG, GIF (Max 5MB)</small>
                        <div id="photoPreview" class="mt-3 text-center"></div>
                    </div>
                    <div class="modal-footer" style="padding: 0; margin-top: 20px;">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="closeModal('#photoModal')">
                            <i class="fas fa-times"></i> Cancel
                        </button>
                        <button type="submit" class="btn btn-amazon">
                            <i class="fas fa-upload"></i> Upload Photo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Specification Modal -->
<!-- Specification Modal -->
<div class="modal fade modal-custom" id="specModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-plus-circle"></i> Add Specification</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="specForm">
                    <input type="hidden" id="specProductId">
                    <div class="mb-3">
                        <label class="form-label">Specification Value</label>
                        <input type="text" id="specValue" class="form-control" placeholder="e.g., Specs" required>
                    </div>
                    <div class="text-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-amazon">Add Specification</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Product Modal -->
<div class="modal fade" id="editProductModal" tabindex="-1" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit"></i> Edit Product
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="closeModal('#editProductModal')">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="editProductContent">
                <!-- Dynamic content will be loaded here -->
                <div class="text-center">
                    <div class="loading-spinner"></div>
                    <p class="mt-2">Loading...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        // ==================== Global Functions ====================

        // Toggle product details
        function toggleProduct(productId) {
            $(`#product-${productId}`).toggleClass('active');
            var icon = $(`.product-header[onclick="toggleProduct(${productId})"] i:first-child`);
            if ($(`#product-${productId}`).hasClass('active')) {
                icon.removeClass('fa-chevron-down').addClass('fa-chevron-up');
            } else {
                icon.removeClass('fa-chevron-up').addClass('fa-chevron-down');
            }
        }

        // Close modal properly
        function closeModal(modalId) {
            $('.modal-backdrop').remove();
            $(modalId).modal('hide');
            $('body').removeClass('modal-open');
            $('body').css('overflow', 'auto');
            $('body').css('padding-right', '');
            $(modalId).removeAttr('style');
            $(modalId).find('.modal-content').removeAttr('style');

            // Reset forms
            $(modalId).find('form').each(function() {
                this.reset();
            });
            $(modalId).find('#photoPreview, #mainPhotoPreview').empty();
        }

        // Search products
        function searchProducts() {
            var searchTerm = $('#searchInput').val();
            if (!searchTerm.trim()) {
                clearSearch();
                return;
            }

            showLoading();
            $.ajax({
                url: '@Url.Action("SearchProducts", "Product")',
                type: 'GET',
                data: { searchTerm: searchTerm },
                success: function(response) {
                    $('#productsList').html(response);
                },
                error: function() {
                    alert('Error searching products');
                },
                complete: function() {
                    hideLoading();
                }
            });
        }

        function clearSearch() {
            $('#searchInput').val('');
            location.reload();
        }

        // Show/hide loading
        function showLoading() {
            $('#productsList').html('<div class="text-center p-5"><div class="loading-spinner"></div><p class="mt-3">Loading...</p></div>');
        }

        function hideLoading() {
            // Loading removed when content loads
        }

        // ==================== Product Operations ====================

    function editProduct(productId) {
        console.log("Opening edit for product ID:", productId);

        // Set loading content
        $('#editProductContent').html(`
            <div class="text-center py-5">
                <div class="spinner-border text-warning" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3">Loading product details...</p>
            </div>
        `);

        // Show modal using Bootstrap 5 syntax
        const editModal = new bootstrap.Modal(document.getElementById('editProductModal'));
        editModal.show();

        // Load product data
        $.ajax({
            url: '/Product/GetProductForEdit',
            type: 'GET',
            data: { id: productId },
            success: function(response) {
                $('#editProductContent').html(response);
                // Reinitialize any dropdowns after content loads
                if (typeof loadCategories === 'function') {
                    loadCategories();
                }
                if (typeof loadManufacturers === 'function') {
                    loadManufacturers();
                }
                if (typeof loadCountries === 'function') {
                    loadCountries();
                }
            },
            error: function(xhr, status, error) {
                console.error("Error:", error);
                $('#editProductContent').html(`
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                        Error loading product details. Please try again.
                        <br><small>${error}</small>
                    </div>
                `);
            }
        });
    }

        // Save edited product
    function saveProductEdit() {
        // Create FormData for the photo
        var formData = new FormData();

        // Add the photo if exists
        var mainPhoto = $('#mainPhoto')[0].files[0];
        if (mainPhoto) {
            formData.append('MainPhoto', mainPhoto);
        }

        // Collect product data into an object
        var productData = {
            ID: parseInt($('input[name="ID"]').val()),
            Name: $('input[name="Name"]').val(),
            Description: $('textarea[name="Description"]').val(),
            Brand: $('input[name="Brand"]').val(),
            Model: $('input[name="Model"]').val(),
            Material: $('input[name="Material"]').val(),
            Color: $('input[name="Color"]').val(),
            Weight: $('input[name="Weight"]').val(),
            Size: $('input[name="Size"]').val(),
            SellingPrice: parseInt($('input[name="SellingPrice"]').val()) || 0,
            PurchasingPrice: parseInt($('input[name="PurchasingPrice"]').val()) || 0,
            Quantity: parseInt($('input[name="Quantity"]').val()) || 0,
            Barcode: $('input[name="Barcode"]').val(),
            ValidFrom: $('input[name="ValidFrom"]').val(),
            IsPublished: $('input[name="IsPublished"]').is(':checked'),
            SubCategoryTBLId: parseInt($('select[name="SubCategoryTBLId"]').val()) || null,
            ManufacturerTBLId: parseInt($('select[name="ManufacturerTBLId"]').val()) || null,
            CountryTBLPlaceId: parseInt($('select[name="CountryTBLPlaceId"]').val()) || null
        };

        // Convert product data to JSON string and append to FormData
        formData.append('productJson', JSON.stringify(productData));

        // Debug: Log what we're sending
        console.log("Sending photo:", mainPhoto ? mainPhoto.name : "No photo");
        console.log("Sending product JSON:", JSON.stringify(productData));

        // Send AJAX
        $.ajax({
            url: '@Url.Action("UpdateProduct", "Product")',
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            beforeSend: function() {
                $('#editProductModal .btn-amazon').prop('disabled', true).html('<span class="loading-spinner"></span> Saving...');
            },
            success: function(response) {
                if (response.success) {
                    closeModal('#editProductModal');
                    location.reload();
                } else {
                    alert(response.message || 'Error updating product');
                    $('#editProductModal .btn-amazon').prop('disabled', false).html('<i class="fas fa-save"></i> Save Changes');
                }
            },
            error: function(xhr, status, error) {
                console.error("Error:", error);
                alert('Error updating product: ' + error);
                $('#editProductModal .btn-amazon').prop('disabled', false).html('<i class="fas fa-save"></i> Save Changes');
            }
        });
    }

        // Delete product
        function deleteProduct(productId, productName) {
            if (confirm(`Are you sure you want to delete "${productName}"? This action cannot be undone.`)) {
                $.ajax({
                    url: '@Url.Action("DeleteProduct", "Product")',
                    type: 'POST',
                    data: { id: productId },
                    success: function(response) {
                        if (response.success) {
                            $(`.product-card[data-product-id="${productId}"]`).fadeOut(300, function() {
                                $(this).remove();
                                if ($('.product-card').length === 0) {
                                    location.reload();
                                }
                            });
                            showNotification('Product deleted successfully', 'success');
                        } else {
                            alert(response.message || 'Error deleting product');
                        }
                    },
                    error: function() {
                        alert('Error deleting product');
                    }
                });
            }
        }

        // ==================== Photo Operations ====================

        function openPhotoModal(productId) {
            $('#photoProductId').val(productId);
            $('#photoPreview').empty();
            $('#photoFile').val('');
            $('#photoModal').modal('show');
        }

        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#photoPreview').html(`
                        <img src="${e.target.result}" style="max-width: 100%; max-height: 250px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <p class="mt-2 text-success">Ready to upload</p>
                    `);
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function deletePhoto(photoId, productId) {
            if (confirm('Are you sure you want to delete this photo?')) {
                $.ajax({
                    url: '@Url.Action("DeleteProductPhoto", "Product")',
                    type: 'POST',
                    data: { id: photoId },
                    success: function(response) {
                        if (response.success) {
                            $(`#photo-${photoId}`).fadeOut(300, function() {
                                $(this).remove();
                                if ($(`#photos-${productId} .photo-item`).length === 0) {
                                    $(`#photos-${productId}`).html('<div class="text-muted">No photos uploaded</div>');
                                }
                            });
                            showNotification('Photo deleted successfully', 'success');
                        } else {
                            alert(response.message || 'Error deleting photo');
                        }
                    },
                    error: function() {
                        alert('Error deleting photo');
                    }
                });
            }
        }

        // ==================== Specification Operations ====================

        function openSpecModal(productId) {
            $('#specProductId').val(productId);
            // $('#specKey').val('');
            $('#specValue').val('');
            $('#specModal').modal('show');
        }

    function deleteSpec(specId, productId) {
        console.log("Deleting spec ID:", specId, "for product:", productId);

        if (confirm('Delete this specification?')) {
            $.ajax({
                url: '/Product/DeleteProductSpecification',
                type: 'POST',
                data: { id: specId },
                success: function(response) {
                    console.log("Delete response:", response);
                    if (response.success) {
                        // Remove the spec from the list
                        $(`#spec-${specId}`).fadeOut(300, function() {
                            $(this).remove();

                            // If no specs left, show "No specifications" message
                            if ($(`#specs-${productId} .spec-item`).length === 0) {
                                $(`#specs-${productId}`).html('<div class="text-muted text-center">No specifications added</div>');
                            }
                        });
                        showNotification('Specification deleted successfully', 'success');
                    } else {
                        alert(response.message || 'Error deleting specification');
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Delete error:", error);
                    console.error("Response:", xhr.responseText);
                    alert('Error deleting specification: ' + error);
                }
            });
        }
    }

        // ==================== Notification ====================

        function showNotification(message, type) {
            var notification = $(`
                <div class="alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show"
                     style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
                    ${message}

                </div>
            `);
            $('body').append(notification);
            setTimeout(function() {
                notification.alert('close');
            }, 3000);
        }

        // ==================== Form Submissions ====================

        $(document).ready(function() {
            // Ensure modals are properly cleaned up
            $('.modal').on('hidden.bs.modal', function() {
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
                $('body').css('overflow', 'auto');
                $('body').css('padding-right', '');
                $(this).removeAttr('style');
            });

            // Handle escape key
            $(document).keyup(function(e) {
                if (e.key === "Escape") {
                    $('.modal').modal('hide');
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');
                }
            });

            // Photo upload form submission
            $('#photoUploadForm').on('submit', function(e) {
                e.preventDefault();
                var formData = new FormData(this);

                $.ajax({
                    url: '@Url.Action("UploadProductPhoto", "Product")',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    beforeSend: function() {
                        $('#photoModal .btn-amazon').prop('disabled', true).html('<span class="loading-spinner"></span> Uploading...');
                    },
                    success: function(response) {
                        if (response.success) {
                            // Get productId from the response or from a variable
                            var productId = $('#photoProductId').val();  // ADD THIS LINE

                            var newPhotoHtml = `
                                <div class="photo-item" id="photo-${response.photoId}">
                                    <img src="/Images/Products/${response.imageName}" class="photo-thumbnail" alt="Product photo">
                                    <button class="btn btn-danger btn-sm" onclick="event.stopPropagation(); deletePhoto(${response.photoId}, ${productId})">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            `;
                            $(`#photos-${productId}`).prepend(newPhotoHtml);

                            $('#photoModal').modal('hide');
                            $('#photoFile').val('');
                        }
                    },
                    error: function() {
                        alert('Error uploading photo');
                        $('#photoModal .btn-amazon').prop('disabled', false).html('<i class="fas fa-upload"></i> Upload Photo');
                    }
                });
            });



                // Add specification without page refresh
    // Add specification without page refresh
    $('#specForm').on('submit', function(e) {
        e.preventDefault();

        const productId = $('#specProductId').val();
        const value = $('#specValue').val();

        if (!value) {
            alert('Please enter specification value');
            return;
        }

        // Disable button and show loading
        const submitBtn = $(this).find('button[type="submit"]');
        const originalText = submitBtn.html();
        submitBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Adding...');

        $.ajax({
            url: '/Product/AddProductSpecification',
            type: 'POST',
            data: { productId: productId, value: value },
            success: function(response) {
                if (response.success) {
                    // Add the new spec to the list dynamically
                    addSpecificationToList(productId, response.specId, value);

                    // Clear form
                    $('#specValue').val('');

                    // Close modal
                    const specModal = bootstrap.Modal.getInstance(document.getElementById('specModal'));
                    specModal.hide();

                    // Show success message
                    showNotification('Specification added successfully!', 'success');
                } else {
                    alert(response.message || 'Error adding specification');
                }
            },
            error: function() {
                alert('Error adding specification');
            },
            complete: function() {
                submitBtn.prop('disabled', false).html(originalText);
            }
        });
    });

    // Function to add specification to the list dynamically
    function addSpecificationToList(productId, specId, value) {
        // Check if specs container exists
        const specsContainer = $(`#specs-${productId}`);

        // If container has "No specifications added" message, remove it
        if (specsContainer.find('.text-muted').length > 0) {
            specsContainer.empty();
        }

        // Create new specification HTML (only value, no key)
        const newSpecHtml = `
            <div class="spec-item" id="spec-${specId}">
                <div>
                    <span class="spec-value">${escapeHtml(value)}</span>
                </div>
                <button class="btn btn-danger btn-sm" onclick="deleteSpec(${specId}, ${productId})">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        `;

        // Append to container
        specsContainer.prepend(newSpecHtml);
    }

    });

        function escapeHtml(text) {
        if (!text) return '';
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }
</script>
