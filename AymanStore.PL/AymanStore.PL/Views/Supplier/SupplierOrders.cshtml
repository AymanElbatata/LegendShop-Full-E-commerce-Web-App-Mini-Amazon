@model SupplierOrders_VM

@{
    ViewData["Title"] = ViewBag.CurrentUser + " Orders";
}

<style>
    body {
        background: #f3f3f3;
    }

    .orders-container {
        padding: 20px 15px;
    }

    .order-card {
        background: #fff;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
        font-size: 14px;
        flex-wrap: wrap;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    .product-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
        flex-shrink: 0;
    }

    .product-info {
        display: flex;
        flex-direction: column;
        flex: 2;
        min-width: 180px;
    }

    .product-name {
        font-weight: 600;
        font-size: 15px;
        line-height: 1.3;
        margin-bottom: 5px;
    }

    .barcode {
        font-size: 13px;
        color: #555;
    }

    /* Client Info Toggle Button */
    .client-toggle {
        cursor: pointer;
        background: #f0f2f2;
        border: 1px solid #d5d9d9;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

        .client-toggle:hover {
            background: #ff9900;
            border-color: #ff9900;
            transform: scale(1.05);
        }

        .client-toggle i {
            font-size: 18px;
            color: #555;
            transition: color 0.3s ease;
        }

        .client-toggle:hover i {
            color: #fff;
        }

    /* Client Info Section - Collapsible */
    .client-info-section {
        width: 100%;
        display: none;
        margin-top: 15px;
        padding-top: 15px;
        border-top: 2px solid #e7e7e7;
        animation: slideDown 0.3s ease;
    }

        .client-info-section.active {
            display: block;
        }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .client-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 12px;
        background: #f8f8f8;
        padding: 15px;
        border-radius: 8px;
    }

    .client-info-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        padding: 8px;
        background: white;
        border-radius: 6px;
        border: 1px solid #e7e7e7;
    }

        .client-info-item i {
            width: 24px;
            color: #ff9900;
            font-size: 16px;
        }

        .client-info-item .label {
            font-weight: 600;
            color: #111;
            min-width: 80px;
        }

        .client-info-item .value {
            color: #555;
            word-break: break-word;
        }

    /* Common styles for all info boxes */
    .quantity, .price, .shipping, .total, .status {
        font-size: 14px;
        color: #555;
        min-width: 90px;
        text-align: center;
        font-weight: 500;
    }

    .quantity {
        font-size: 16px;
        font-weight: 600;
        color: #111;
    }

    .price {
        font-size: 15px;
        font-weight: 600;
        color: #2e7d32;
    }

    .shipping {
        font-size: 13px;
        color: #007185;
    }

    .total {
        font-size: 16px;
        font-weight: 700;
        color: #b12704;
    }

    .status {
        font-size: 14px;
        font-weight: 600;
    }

    .status-select {
        height: 38px;
        font-size: 14px;
        padding: 6px 10px;
        min-width: 130px;
        border-radius: 6px;
        border: 1px solid #ddd;
    }

    .btn-amazon {
        background: #ff9900;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        color: #000;
        height: 38px;
        white-space: nowrap;
        cursor: pointer;
    }

        .btn-amazon:hover {
            background: #e68a00;
        }

    form.d-flex {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: nowrap;
    }

    /* Tablet Styles (768px to 991px) */
    @@media (max-width: 991px) and (min-width: 768px) {
        .orders-container {
            padding: 15px;
        }

        .order-card {
            padding: 12px 15px;
            gap: 10px;
        }

        .product-img {
            width: 70px;
            height: 70px;
        }

        .product-info {
            min-width: 150px;
            flex: 1;
        }

        .product-name {
            font-size: 14px;
        }

        .barcode {
            font-size: 12px;
        }

        .quantity, .price, .shipping, .total, .status {
            min-width: 75px;
            font-size: 12px;
        }

        .quantity {
            font-size: 14px;
        }

        .price {
            font-size: 13px;
        }

        .total {
            font-size: 14px;
        }

        .status-select {
            height: 36px;
            font-size: 13px;
            min-width: 110px;
        }

        .btn-amazon {
            height: 36px;
            font-size: 13px;
            padding: 6px 14px;
        }

        .client-toggle {
            width: 32px;
            height: 32px;
        }

            .client-toggle i {
                font-size: 16px;
            }

        .client-info-grid {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 10px;
        }

        .client-info-item {
            font-size: 12px;
        }

            .client-info-item .label {
                min-width: 70px;
            }
    }

    /* Mobile Styles (up to 767px) */
    @@media (max-width: 767px) {
        .orders-container {
            padding: 10px;
        }

        h5.mb-3 {
            font-size: 18px;
            margin-bottom: 12px !important;
        }

        .order-card {
            flex-direction: column;
            align-items: stretch;
            padding: 15px;
            gap: 12px;
        }

        .product-img {
            width: 100px;
            height: 100px;
            margin-bottom: 5px;
        }

        .product-info {
            width: 100%;
            min-width: unset;
        }

        .product-name {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .barcode {
            font-size: 13px;
            padding: 4px 0;
        }

            .barcode::before {
                content: "📦 Barcode: ";
                font-weight: 600;
                color: #111;
            }

        .quantity, .price, .shipping, .total, .status {
            text-align: left;
            min-width: unset;
            width: 100%;
            padding: 8px 0;
            font-size: 14px;
        }

            .quantity::before {
                content: "🔢 Quantity: ";
                font-weight: 600;
                color: #111;
            }

            .price::before {
                content: "💰 Price: ";
                font-weight: 600;
                color: #111;
            }

            .shipping::before {
                content: "🚚 Shipping: ";
                font-weight: 600;
                color: #111;
            }

            .total::before {
                content: "💵 Total: ";
                font-weight: 600;
                color: #111;
            }

            .status::before {
                content: "📊 Status: ";
                font-weight: 600;
                color: #111;
            }

        .status-display {
            display: inline-block;
            width: auto;
            font-weight: 600;
        }

        form.d-flex {
            width: 100%;
            margin-top: 5px;
            flex-direction: column;
            align-items: stretch;
        }

        .status-select {
            width: 100%;
            min-width: unset;
            height: 44px;
            font-size: 15px;
            padding: 8px 12px;
        }

        .btn-amazon {
            width: 100%;
            height: 44px;
            font-size: 15px;
            padding: 8px 16px;
        }

        .order-card form {
            width: 100%;
        }

        .client-toggle {
            width: 40px;
            height: 40px;
            align-self: flex-start;
        }

        .client-info-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .client-info-item {
            font-size: 13px;
        }
    }

    /* Small Mobile Devices (up to 480px) */
    @@media (max-width: 480px) {
        .orders-container {
            padding: 8px;
        }

        h5.mb-3 {
            font-size: 16px;
        }

        .order-card {
            padding: 12px;
        }

        .product-img {
            width: 80px;
            height: 80px;
        }

        .product-name {
            font-size: 15px;
        }

        .barcode, .quantity, .price, .shipping, .total, .status {
            font-size: 13px;
            padding: 6px 0;
        }

        .status-select {
            height: 42px;
            font-size: 14px;
        }

        .btn-amazon {
            height: 42px;
            font-size: 14px;
        }

        .client-info-item .label {
            min-width: 70px;
        }
    }

    /* Landscape mode for mobile */
    @@media (max-width: 767px) and (orientation: landscape) {
        .order-card {
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
        }

        .product-info {
            flex: 2;
            min-width: 180px;
        }

        .quantity, .price, .shipping, .total, .status {
            width: auto;
            min-width: 80px;
        }

            .quantity::before, .price::before, .shipping::before, .total::before, .status::before {
                display: none;
            }

        form.d-flex {
            flex-direction: row;
            width: auto;
        }

        .status-select {
            width: auto;
            min-width: 120px;
        }

        .btn-amazon {
            width: auto;
        }

        .client-toggle {
            align-self: center;
        }
    }

    .tracking-editable {
        padding: 3px 6px;
        border-radius: 4px;
    }

        .tracking-editable:hover {
            background-color: #f1f1f1;
            cursor: text;
        }
    /* Search Bar */
    .search-bar {
        background: white;
        padding: 25px;
        border-radius: 8px;
        margin-bottom: 25px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

        .search-bar input {
            border: 2px solid #ddd;
            border-radius: 4px;
            padding: 12px;
            font-size: 16px;
        }

            .search-bar input:focus {
                border-color: #ff9900;
                outline: none;
                box-shadow: 0 0 0 2px rgba(255,153,0,0.2);
            }

</style>


<div class="container">
    <div class="breadcrumb">
        <span> @ViewBag.CurrentUser > Orders</span>
    </div>
</div>


<form asp-controller="Supplier" asp-action="SupplierOrders" method="get">
    <div class="search-bar">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="input-group">
                    <input type="text"
                           name="barcode"
                           class="form-control"
                           placeholder="Search orders by barcode..." />

                    <div class="input-group-append d-flex justify-content-center align-items-center ms-1">
                        <button type="submit" class="btn btn-amazon">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="container-fluid orders-container">

    @if (Model.OrderDetailTBL_VM == null || !Model.OrderDetailTBL_VM.Any())
    {
        <div class="text-center mt-4">
            <p>No orders found.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model.OrderDetailTBL_VM)
        {
            <div class="order-card">

                <!-- Image -->
                <a asp-controller="Home" asp-action="ProductDetail" asp-route-ProductId="@item.ProductTBL.ID">
                    <img src="~/Images/Products/@item.ProductTBL?.Image" class="product-img" alt="Product" />
                </a>

                <!-- Product Info -->
                <div class="product-info">
                    <div class="product-name">@item.ProductTBL?.Name</div>
                    <div class="barcode">BC: @item.ProductTBL?.Barcode</div>
                    <div class="barcode">Order: @item.OrderTBL?.HashCode</div>
                </div>

                <!-- Client Toggle Button (Plus/Minus Icon) -->
                <div class="client-toggle" data-order-id="@item.OrderTBLId">
                    <i class="fas fa-plus"></i>
                </div>

                <!-- Quantity -->
                <div class="quantity">Quantity: @item.Quantity</div>

                <div class="price">Price: @item.Price $</div>

                <div class="shipping">Shipping: @item.ShippingCost $</div>

                <!-- Total -->
                <div class="total">
                    Total: @(((item.Price ?? 0) * (item.Quantity ?? 0)) + ((item.ShippingCost ?? 0) * (item.Quantity ?? 0))) $
                </div>

                <!-- Status Display -->
                <div class="status status-display">@item.ShippingStatusTBL?.Name</div>

                <!-- Update Form -->
                <form asp-action="UpdateOrderDetailStatus" asp-controller="Supplier" method="post" class="d-flex gap-2 align-items-center flex-nowrap">
                    <input type="hidden" name="orderDetailId" value="@item.ID" />

                    <select name="statusId" class="form-select status-select" @(item.ShippingStatusTBLId == 5 || item.ShippingStatusTBLId == 4 ? "disabled" : "")>
                        @foreach (var status in Model.ShippingStatusOptions)
                        {
                            var current = item.ShippingStatusTBLId ?? 1;
                            var statusValue = int.Parse(status.Value);

                            <option value="@status.Value" selected="@(statusValue == current)">
                                @status.Text
                            </option>
                        }
                    </select>
                </form>

                <!-- Collapsible Client Information Section -->
                <div class="client-info-section" data-order-id="@item.OrderTBLId">
                    <div class="client-info-grid">
                        <div class="client-info-item">
                            <i class="fas fa-calendar-alt"></i>
                            <span class="label">Order Date:</span>
                            <span class="value">
                                @item.OrderTBL?.DateOfSubmit?.Date.ToString("dddd, MMMM yyyy")
                            </span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-truck"></i>
                            <span class="label">Shipping Service:</span>
                            <span class="value">@item.OrderTBL?.ShippingServiceTBL?.Name/@item.OrderTBL?.ShippingServiceTBL?.Description</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-shipping-fast"></i>
                            <span class="label">Shipping Office:</span>
                            <span class="value">@item.ShippingCompanyCostTBL?.ShippingCompanyTBL?.Name</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-barcode"></i>
                            <span class="label">Shipping Code:</span>

                            <span class="value tracking-editable"
                                  contenteditable="true"
                                  data-id="@item.ID">
                                @item.ShippingCompanyTRKCode
                            </span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span class="label">From:</span>
                            <span class="value">@item.ShippingCompanyCostTBL?.CountryTBLSendFrom?.Name</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span class="label">To:</span>
                            <span class="value">@item.ShippingCompanyCostTBL?.CountryTBLSendTo?.Name</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-home"></i>
                            <span class="label">Address:</span>
                            <span class="value">@item.OrderTBL?.ClientAddress</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-user"></i>
                            <span class="label">Full Name:</span>
                            <span class="value">@item.OrderTBL?.ClientName</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-envelope"></i>
                            <span class="label">Email:</span>
                            <span class="value">@item.OrderTBL?.ClientEmail</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-phone"></i>
                            <span class="label">Phone:</span>
                            <span class="value">@item.OrderTBL?.ClientPhones</span>
                        </div>
                        <div class="client-info-item">
                            <i class="fas fa-sticky-note"></i>
                            <span class="label">Notes:</span>
                            <span class="value">@(string.IsNullOrEmpty(item.OrderTBL?.ClientNotes) ? "No notes" : item.OrderTBL?.ClientNotes)</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>



<script>
    $(document).on("blur", ".tracking-editable", function () {

        var el = $(this);
        var newValue = el.text().trim();
        var id = el.data("id");

        $.ajax({
            url: '/Supplier/UpdateTrackingCode',
            type: 'POST',
            data: {
                id: id,
                trackingCode: newValue
            },
            success: function () {
                el.css("border", "1px solid green");
                setTimeout(() => el.css("border", "none"), 1000);
            },
            error: function () {
                el.css("border", "1px solid red");
            }
        });
    });

</script>

<script>
    $(document).ready(function () {
        // Toggle client info section
        $(".client-toggle").click(function () {
            var $toggle = $(this);
            var $clientSection = $toggle.closest(".order-card").find(".client-info-section");

            $clientSection.slideToggle(200, function() {
                if ($clientSection.is(":visible")) {
                    $toggle.find("i").removeClass("fa-plus").addClass("fa-minus");
                } else {
                    $toggle.find("i").removeClass("fa-minus").addClass("fa-plus");
                }
            });
        });

        // Status update AJAX
        $(".status-select").change(function () {
            var select = $(this);
                    if (!confirm("Are you sure you want to update the order status?")) {
            return; // ❌ Do nothing at all
        }

            var orderDetailId = select.closest("form").find("input[name='orderDetailId']").val();
            var statusId = select.val();

                    if (statusId == 4|| statusId == 5) {
            select.prop("disabled", true);
        }
            $.ajax({
                url: '@Url.Action("UpdateOrderDetailStatus", "Supplier")',
                type: 'POST',
                data: { orderDetailId: orderDetailId, statusId: statusId },
                success: function (response) {
                    if (response.success) {
                        select.closest(".order-card").find(".status-display").text(response.statusText);
                        // Show temporary success message
                        var statusDiv = select.closest(".order-card").find(".status");
                        statusDiv.css("background", "#d4edda");
                        setTimeout(function() {
                            statusDiv.css("background", "");
                        }, 1000);
                    } else {
                        alert("Failed to update status.");
                    }
                },
                error: function () {
                    alert("Error updating status.");
                }
            });
        });
    });
</script>

