@model List<AbuseProductRatingTBL_VM>

@{
    ViewData["Title"] = "Review's Reports";
}

<style>
    .table th {
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .table td {
        vertical-align: middle;
    }

    .text-wrap {
        white-space: normal;
        word-break: break-word;
    }

    img {
        border: 1px solid #e0e0e0;
    }
</style>

<div class="container">
    <div class="breadcrumb">
        <span>Admin > Review's Reports</span>
    </div>
</div>


<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
@*             <h2 class="fw-bold mb-1" style="color: #232f3e;">
                <i class="fas fa-flag me-2" style="color: #ff9900;"></i>Reviews Reports
            </h2>
            <p class="text-muted small mb-0">View reported review issues</p>
 *@        </div>
        <div class="mt-2 mt-md-0">
            <span class="badge bg-danger px-3 py-2">
                <i class="fas fa-inbox me-1"></i> Total: @Model.Count
            </span>
        </div>
    </div>

    <!-- Reports Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Product</th>
                            <th>Sender</th>
                            <th>Subject</th>
                            <th>Comment</th>
                            <th>Reported Issue</th>
                            <th>Report Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID">
                                <td class="ps-3">@counter</td>
                                <td style="min-width: 250px;">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(item.ProductRatingTBL.ProductTBL?.Image))
                                        {
                                            <a asp-controller="Home" asp-action="ProductDetail" asp-route-ProductId="@item.ProductRatingTBL.ProductTBL.ID">
                                                <img src="~/Images/Products/@item.ProductRatingTBL.ProductTBL.Image" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" />
                                            </a>
                                        }
                                            <div>
                                            <div class="fw-semibold">@(item.ProductRatingTBL?.ProductTBL?.Name ?? "N/A")</div>
                                            <small class="text-muted">
                                                BC: @(item.ProductRatingTBL?.ProductTBL?.Barcode ?? "NA")
                                            </small>
                                        </div>
                                    </div>
                                </td>
                                <td style="max-width: 250px;">
                                    <div class="text-wrap text-muted">
                                        "@(item.SenderUserTBL?.UserName ?? "User")"
                                    </div>
                                </td>
                                <td style="max-width: 250px;">
                                    <div class="text-wrap text-muted">
                                        "@(item.ProductRatingTBL?.ReviewSubject ?? "No Subject")"
                                    </div>
                                </td>
                                <td style="max-width: 250px;">
                                    <div class="text-wrap text-muted">
                                        "@(item.ProductRatingTBL?.ReviewComment ?? "No Comment")"
                                    </div>
                                </td>
                                <td style="max-width: 300px;">
                                    <div class="text-wrap text-danger">@item.Message</div>
                                </td>
                                <td>
                                    <div>@item.CreationDate?.ToString("dd-MM-yyyy")</div>
                                    <small class="text-muted">@item.CreationDate?.ToString("HH:mm:ss")</small>
                                </td>
                            </tr>
                            counter++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-4x text-muted mb-3 d-block"></i>
                <h5 class="text-muted">No Reports Found</h5>
                <p class="text-muted small">Reported reviews will appear here</p>
            </div>
        </div>
    }
</div>
