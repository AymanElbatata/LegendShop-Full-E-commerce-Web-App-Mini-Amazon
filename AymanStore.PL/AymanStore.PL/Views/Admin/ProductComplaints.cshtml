@model List<ContactForProductErrorTBL_VM>

@{
    ViewData["Title"] = "Read Product's Complaints";
}

<style>
    .table th {
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .table td {
        vertical-align: middle;
    }

    .text-wrap {
        white-space: normal;
        word-break: break-word;
    }

    .badge {
        font-weight: 500;
        padding: 5px 10px;
    }
</style>


<div class="container">
    <div class="breadcrumb">
        <span>Admin > Product's' Complaints</span>
    </div>
</div>


<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
@*             <h2 class="fw-bold mb-1" style="color: #232f3e;">
                <i class="fas fa-exclamation-triangle me-2" style="color: #ff9900;"></i>Product Complaints
            </h2>
            <p class="text-muted small mb-0">View customer product issues and complaints</p>
 *@        </div>
        <div class="mt-2 mt-md-0">
            <span class="badge bg-danger px-3 py-2">
                <i class="fas fa-envelope me-1"></i> Total: @Model.Count
            </span>
        </div>
    </div>

    <!-- Complaints Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Customer</th>
                            <th>Product</th>
                            <th>Supplier</th>
                            <th>Complaint</th>
                            <th>Admin Reply</th>
                            <th>Status</th>
                            <th>Creation</th>
                            <th>Reply</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID">
                                <td class="ps-3">@counter</td>
                                <td>
                                    <div class="fw-semibold">@(item.SenderUserTBL?.UserName ?? "Unknown")</div>
                                    <small class="text-muted">@(item.SenderUserTBL?.Email ?? "No email")</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(item.ProductTBL?.Image))
                                        {
                                            <a asp-controller="Home" asp-action="ProductDetail" asp-route-ProductId="@item.ProductTBL.ID">
                                            <img src="~/Images/Products/@item.ProductTBL.Image" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" />
                                            </a>
                                        }
                                        <div>
                                            <div class="fw-semibold">@(item.ProductTBL?.Name ?? "N/A")</div>
                                            <small class="text-muted">BC: @(item.ProductTBL?.Barcode ?? "N/A")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(item.ProductTBL?.SupplierTBL?.UserName ?? "N/A")</td>
                                <td style="max-width: 250px;">
                                    <div class="text-wrap">@item.Message</div>
                                </td>
                                <td style="max-width: 200px;">
                                    @if (!string.IsNullOrEmpty(item.MessageReplyToClient))
                                    {
                                        <div class="text-wrap text-success">@item.MessageReplyToClient</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No reply yet</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.MessageReplyToClient))
                                    {
                                        <span class="badge bg-success">Replied</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                                <td>
                                    <div>@item.CreationDate?.ToString("dd-MM-yyyy")</div>
                                    <small class="text-muted">@item.CreationDate?.ToString("HH:mm:ss")</small>
                                </td>
                                <td>
                                    <div>@item.LastUpdateDate?.ToString("dd-MM-yyyy")</div>
                                    <small class="text-muted">@item.LastUpdateDate?.ToString("HH:mm:ss")</small>
                                </td>
                            </tr>
                            counter++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-4x text-muted mb-3 d-block"></i>
                <h5 class="text-muted">No Complaints Found</h5>
                <p class="text-muted small">Customer complaints will appear here</p>
            </div>
        </div>
    }
</div>