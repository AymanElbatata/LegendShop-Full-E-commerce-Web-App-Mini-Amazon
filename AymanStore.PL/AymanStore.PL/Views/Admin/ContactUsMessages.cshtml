@model List<ContactUsTBL_VM>

@{
    ViewData["Title"] = "Contact Us Messages";
}

<style>
    .table th {
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .table td {
        vertical-align: middle;
    }

    .text-wrap {
        white-space: normal;
        word-break: break-word;
    }

</style>

<div class="container">
    <div class="breadcrumb">
        <span>Admin > Contact Us Messages</span>
    </div>
</div>

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
@*             <h2 class="fw-bold mb-1" style="color: #232f3e;">
                <i class="fas fa-envelope me-2" style="color: #ff9900;"></i>Contact Us Messages
            </h2>
            <p class="text-muted small mb-0">View customer inquiries and messages</p>
 *@        </div>
        <div class="mt-2 mt-md-0">
            <span class="badge bg-danger px-3 py-2">
                <i class="fas fa-inbox me-1"></i> Total: @Model.Count
            </span>
        </div>
    </div>

    <!-- Messages Table -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Message</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr id="row_@item.ID">
                                <td class="ps-3">@counter</td>
                                <td>
                                    <div class="fw-semibold">@(item.Name ?? "N/A")</div>
                                </td>
                                <td>
                                    <a href="mailto:@item.Email" class="text-decoration-none text-black">@(item.Email ?? "N/A")</a>
                                </td>
                                <td style="max-width: 400px;">
                                    <div class="text-wrap">@item.Message</div>
                                </td>
                                <td>
                                    <div>@item.CreationDate?.ToString("dd-MM-yyyy")</div>
                                    <small class="text-muted">@item.CreationDate?.ToString("HH:mm:ss")</small>
                                </td>
                            </tr>
                            counter++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-4x text-muted mb-3 d-block"></i>
                <h5 class="text-muted">No Messages Found</h5>
                <p class="text-muted small">Customer messages will appear here</p>
            </div>
        </div>
    }
</div>