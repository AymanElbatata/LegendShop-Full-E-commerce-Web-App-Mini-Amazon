@model AymanStore.PL.DTO.RegisterDTO

@{
    ViewData["Title"] = "Register";
}


<style>


    /* Registration Container */
    .registration-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        flex-grow: 1;
        padding: 40px 0;
    }

    .registration-box {
        background-color: white;
        border-radius: 4px;
        padding: 20px 26px;
        width: 400px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }

    .registration-title {
        font-weight: 400;
        font-size: 28px;
        margin-bottom: 20px;
        color: #232F3E;
    }

    .form-group {
        margin-bottom: 14px;
    }

    .form-label {
        display: block;
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 2px;
        padding-left: 2px;
    }

    .form-input, .form-select {
        width: 100%;
        height: 31px;
        padding: 3px 7px;
        border: 1px solid #a6a6a6;
        border-radius: 3px;
        font-size: 13px;
        background-color: white;
    }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #e77600;
            box-shadow: 0 0 3px 2px rgba(228, 121, 17, 0.5);
        }

    .text-danger {
        color: #c40000;
        font-size: 12px;
        margin-top: 3px;
        display: block;
    }

    .registration-btn {
        width: 100%;
        background: linear-gradient(to bottom, #f7dfa5, #f0c14b);
        border: 1px solid #a2a6ac;
        border-radius: 3px;
        padding: 8px 0;
        font-size: 13px;
        cursor: pointer;
        margin-top: 10px;
    }

        .registration-btn:hover {
            background: linear-gradient(to bottom, #f5d78e, #eeb933);
        }

        .registration-btn:disabled {
            background: #e7e9ec;
            cursor: not-allowed;
        }

    .registration-agreement {
        font-size: 12px;
        margin: 18px 0;
        line-height: 1.5;
    }

    .registration-divider {
        text-align: center;
        position: relative;
        margin: 20px 0;
        font-size: 12px;
        color: #767676;
    }

        .registration-divider::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background-color: #e7e7e7;
            z-index: 1;
        }

        .registration-divider span {
            background-color: white;
            padding: 0 8px;
            position: relative;
            z-index: 2;
        }

    .login-redirect {
        text-align: center;
        margin-top: 20px;
        font-size: 13px;
    }


    /* Name fields layout */
    .name-fields {
        display: flex;
        gap: 10px;
    }

        .name-fields .form-group {
            flex: 1;
        }

    /* Validation Summary */
    .validation-summary {
        color: #c40000;
        background-color: #ffdfdf;
        padding: 10px;
        border-radius: 3px;
        margin-bottom: 15px;
        font-size: 13px;
    }

        .validation-summary ul {
            margin-left: 15px;
        }

</style>

<div class="container">
    <div class="breadcrumb">
        <span>Account > Register</span>
    </div>
</div>

@if (Model?.Errors != null && Model.Errors.Any())
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var errorGroup in Model.Errors)
            {
                foreach (var msg in errorGroup.Value)
                {
                    <li>@msg</li>
                }
            }
        </ul>
    </div>
}

<!-- Registration Container -->
<div class="registration-container">

    <div class="registration-box">
        <h1 class="registration-title">Create Account</h1>

        <!-- Validation Summary -->
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form id="registrationForm" method="post" asp-controller="Account" asp-action="Register">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="text" asp-for="Email" class="form-input" placeholder="Enter your email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" asp-for="Password" class="form-input" placeholder="Create a password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Confirm Password</label>
                <input type="password" asp-for="ConfirmPassword" class="form-input" placeholder="Confirm your password" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="name-fields">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input type="text" asp-for="FirstName" class="form-input" placeholder="First name" required maxlength="20" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input type="text" asp-for="LastName" class="form-input" placeholder="Last name" required maxlength="20" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="name-fields">
            <div class="form-group">
                <label asp-for="GenderTBLId" class="form-label"></label>
                <select asp-for="GenderTBLId"
                        asp-items="Model.GenderOptions"
                        class="form-select select2"
                        id="genderTBLId">
                    <option value="">Select Gender</option>
                </select>
                <span asp-validation-for="GenderTBLId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TypeId" class="form-label"></label>
                <select asp-for="TypeId" class="form-select select2" id="typeId" required>
                    <option value="">Select Type</option>
                    <option value="1">Client</option>
                    <option value="2">Supplier</option>
                </select>
                <span asp-validation-for="TypeId" class="text-danger"></span>
            </div>
            </div>

            <div class="form-group">
                <label asp-for="CountryTBLId" class="form-label"></label>
                <select asp-for="CountryTBLId"
                        asp-items="Model.CountryOptions"
                        class="form-select select2"
                        id="countryTBLId">
                    <option value="">Select Country</option>
                </select>
                <span asp-validation-for="CountryTBLId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Address</label>
                <input type="text" asp-for="Address" class="form-input" placeholder="Your address includes your city" required maxlength="100" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Phone</label>
                <input type="text" asp-for="Phone" class="form-input" placeholder="Your phone number" required maxlength="20" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <button type="submit" class="registration-btn">Create your Legend Shop account</button>
        </form>

        <p class="registration-agreement">
            By creating an account, you agree to Legend Shop
            <a asp-controller="Home" asp-action="ConditionsofUse" style="color: #0066C0;">Conditions of Use</a> and
            <a asp-controller="Home" asp-action="PrivacyNotice" style="color: #0066C0;">Privacy Notice</a>.
        </p>

        <div class="registration-divider">
            <span>Already have an account?</span>
        </div>

        <div class="login-redirect">
            <a asp-controller="Account" asp-action="Login" style="color: #0066C0;">
                Sign in to your account
            </a>
        </div>
    </div>
</div>


@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            $('.select2').select2({
                placeholder: "Select",
                allowClear: true,
                width: '100%'
            }).on('change', function () {
                $(this).valid(); // 🔥 THIS is the fix
            });

        });
    </script>

}